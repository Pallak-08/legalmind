# Required
GROQ_API_KEY=gsk_replace_me

# Optional overrides
GROQ_MODEL=llama-3.3-70b-versatile
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-base
CHROMA_PERSIST_DIR=./chroma_data

# Retrieval tuning
TOP_K_DENSE=15
TOP_K_BM25=15
TOP_K_RERANK=5

# Server
# For local dev: http://localhost:3000
# For Railway: set to your frontend's public URL, e.g. https://legalmind-frontend.up.railway.app
# Comma-separate multiple. Use "*" only for smoke-testing — disables credentialed CORS.
CORS_ORIGINS=http://localhost:3000
MAX_UPLOAD_MB=20

# Railway: set this to a path inside your mounted volume, e.g. /data/chroma
# Otherwise ChromaDB writes to the container's ephemeral filesystem and you
# lose all indexed contracts on every redeploy.
# CHROMA_PERSIST_DIR=/data/chroma

# Railway: cache HuggingFace model downloads on a persistent volume so they
# don't redownload on every deploy (~1.3 GB)
# HF_HOME=/data/hf-cache
